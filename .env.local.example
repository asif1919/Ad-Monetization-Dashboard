# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only for server-side admin operations (e.g. service role)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Currency display: USD is stored everywhere; BDT is for display only.
# Optional: custom FX API URL (default: Frankfurter). Response must include USD→BDT rate (e.g. rates.BDT or conversion_rate).
# FX_API_URL=https://api.frankfurter.dev/v1/latest?base=USD&symbols=BDT
# Fallback rate when API fails or is missing (used until next successful fetch).
# FX_USD_BDT_FALLBACK=110
